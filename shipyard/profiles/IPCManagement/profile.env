# profiles/IPCManagement/profile.env — IPCManagement stack shape
# Modified from PostgreSQL to MySQL for IPCManagement

DB_URL_SCHEME="mysql"                              # MySQL driver scheme
API_PATH=""                                        # E2E scripts already include /api
UPLOAD_SUBDIR="backend/data/uploads"               # per-lane upload dir
BACKEND_DIR="backend"                              # backend subdir
FRONTEND_DIR="frontend"                            # frontend subdir
DB_SERVICE="mysql"                                 # docker-compose service name for DB
COMPOSE_SERVICES=""                                # MySQL is an existing Windows service
BASE_BRANCH="main"                                 # repository default branch
INTEGRATION_BRANCH="feature/production-plan"       # current integration branch
BRANCH_PREFIX="feature/"                           # feature-branch prefix
TEST_PATHS="backend/tests"                         # test paths for fast-path
GENERATED_MERGE_PATHS=""                           # no generated files in this project
MIGRATIONS_DIR="backend/src/IPCManagement.Api/Migrations"
QC_BOOT_ENV=""                                    # no special QC env needed
DB_LIFECYCLE_HOOKS="1"                             # profile owns MySQL create/reset
QA_TOKEN_KEY="access_token"                        # localStorage key for auth
QA_REFRESH_KEY="refresh_token"                     # refresh token key
QA_ORG_KEY=""
